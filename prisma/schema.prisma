// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User Management
//
// All user types share this table, distinguished by `role`:
//   - Admin / staff users (SUPER_ADMIN / CONTENT_EDITOR / CHILDREN_LEADER /
//     VIEWER) authenticate via the cookie-based email-and-password login.
//   - YOUTH users authenticate via Google OAuth (Auth.js) for the youth
//     portal — they have no `passwordHash` and get a profile `image` from
//     Google.
//   - PARENT is a deprecated legacy role. Children check-in is now handled
//     by CHILDREN_LEADER from /dashboard/children; the parent self-service
//     OAuth flow has been removed. Existing PARENT rows are retained for
//     check-in-history integrity but cannot log in.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String
  phoneNumber   String?
  position      String?
  mustChangePassword Boolean @default(true)
  image         String?
  emailVerified DateTime?
  role          UserRole  @default(VIEWER)
  // Designated Safeguarding Lead flag — orthogonal to `role`. A user can be
  // a CHILDREN_LEADER who is also the DSL. Only DSLs (and SUPER_ADMINs) can
  // read / manage the safeguarding concern log.
  isDesignatedSafeguardingLead Boolean @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions       Session[]
  twoFactorCodes TwoFactorCode[]
  auditLogs      AuditLog[]
  // Safeguarding concerns this user has raised.
  concernsRaised SafeguardingConcern[] @relation("ConcernRaisedBy")
  concernsClosed SafeguardingConcern[] @relation("ConcernClosedBy")
  // Right-to-erasure requests this user has actioned (completed/dismissed).
  erasureRequestsHandled ErasureRequest[] @relation("ErasureHandledBy")

  // Auth.js (NextAuth v5) relations — populated for OAuth-authenticated
  // YOUTH users. Empty for admin-cookie users.
  accounts     Account[]
  authSessions AuthSession[]

  // Check-in audit trail: records the staff member (CHILDREN_LEADER or
  // SUPER_ADMIN) who signed a child in / out.
  checkInsCreated  ChildCheckIn[] @relation("CheckInSignedInBy")
  checkInsClosed   ChildCheckIn[] @relation("CheckInSignedOutBy")

  // Youth ministry check-ins
  youthCheckIns    YouthCheckIn[]
  // Web-push subscriptions (youth opt in on the youth portal to receive
  // "please sign out" reminders).
  pushSubscriptions PushSubscription[]

  @@index([email])
  @@index([role])
}

// A browser Web-Push subscription belonging to a youth member. One youth
// may have several (different devices/browsers). Pruned automatically when
// the push service reports the subscription gone (HTTP 404/410).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UserRole {
  SUPER_ADMIN
  CONTENT_EDITOR
  CHILDREN_LEADER
  YOUTH_LEADER     // Staff who manage the youth ministry (dashboard access).
  VIEWER
  PARENT  // Deprecated — see User docblock.
  YOUTH   // Youth *members* — Google-OAuth youth-portal accounts.
}

// =========================================================================
// Auth.js (NextAuth v5) tables — required by @auth/prisma-adapter
// =========================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Auth.js session table. Distinct from the existing `Session` model used
// by the legacy admin login flow.
model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =========================================================================
// Children Ministry — registration + check-in / check-out
// =========================================================================

// Child records are owned by the children's ministry, not by parent
// accounts. The Children Leader registers each child and captures the
// primary guardian's contact details plus a separate emergency contact.
//
// `approved` gates whether the child shows up on the live roster. Records
// created by the Children Leader from /dashboard/children are approved
// automatically. Records created by parents from the public /parent/register
// form are saved as `approved=false` and must be reviewed by a Children
// Leader before they appear on the active roster.
model Child {
  id                       String    @id @default(cuid())
  firstName                String
  lastName                 String
  dateOfBirth              DateTime  @db.Date
  gender                   Gender
  // Free-text duty-of-care fields. Empty string is normalized to null.
  allergies                String?   @db.Text
  medicalNotes             String?   @db.Text
  specialNeeds             String?   @db.Text
  // Child photo. New uploads are stored as Cloudinary `authenticated`
  // assets — we keep the public_id and generate a signed delivery URL on
  // read so the image can't be viewed by anyone who merely has a URL.
  // `photoUrl` remains for legacy public uploads (pre-authentication) and
  // any externally-hosted URL; `photoPublicId` takes precedence when set.
  photoUrl                 String?
  photoPublicId            String?

  // Primary guardian — the day-to-day contact who drops the child off /
  // picks them up. The Children Leader uses these details for routine
  // contact.
  primaryGuardianName      String
  primaryGuardianPhone     String
  primaryGuardianEmail     String?

  // Emergency contact — a second person (different from the primary
  // guardian) to call if the primary cannot be reached.
  emergencyContactName     String
  emergencyContactPhone    String
  emergencyContactRelation String

  // Approval gate — see docblock above.
  approved                 Boolean   @default(true)

  // UK GDPR Article 6 + Article 9 consent capture. Required at registration
  // for the children's-ministry to lawfully process the child's data and
  // (especially) the special-category fields (health / allergies). To
  // withdraw consent later, flip these to false rather than deleting the
  // record so the audit trail survives.
  consentDataProcessing      Boolean   @default(false)
  consentPhotography         Boolean   @default(false)
  consentMedicalInfoSharing  Boolean   @default(false)
  consentEmergencyTreatment  Boolean   @default(false)
  // When the consent was captured + who gave it (text snapshot — usually
  // the primary guardian's name, but recorded explicitly so historical
  // changes to the guardian record don't corrupt the consent audit).
  consentCapturedAt          DateTime?
  consentByName              String?

  checkIns             ChildCheckIn[]
  authorisedCollectors AuthorisedCollector[]
  safeguardingConcerns SafeguardingConcern[]
  erasureRequests      ErasureRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastName, firstName])
  @@index([approved])
}

// UK GDPR right-to-erasure request raised by a parent/guardian via the
// public form. Staff review the queue and run the "erase all data" action.
// `childId` is a best-effort match made at submission time (exact name +
// guardian email); it's nullable because the parent doesn't know record IDs
// and there may be no/ambiguous match — the admin confirms the child when
// actioning. On the child being deleted, `childId` is set null (the request
// is retained as a record that the erasure was carried out).
model ErasureRequest {
  id            String         @id @default(cuid())
  childName     String
  guardianName  String
  guardianEmail String
  message       String?        @db.Text
  status        ErasureStatus  @default(PENDING)
  childId       String?
  handledById   String?
  handledAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  child     Child? @relation(fields: [childId], references: [id], onDelete: SetNull)
  // The staff member who actioned the request. Kept (SetNull) if that user is
  // later removed, so the request's audit trail survives.
  handledBy User?  @relation("ErasureHandledBy", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

enum ErasureStatus {
  PENDING
  COMPLETED
  DISMISSED
}

// Adults authorised by the guardian to collect a specific child. The
// primary guardian is implicitly authorised (their details live on Child
// itself); this table holds *additional* named adults (grandparents, aunts
// and uncles, family friends). At sign-out the Children Leader picks who
// is collecting; the chosen name + relationship are snapshotted onto the
// ChildCheckIn row so the audit trail survives later edits to this list.
model AuthorisedCollector {
  id           String   @id @default(cuid())
  childId      String
  name         String
  relationship String
  phone        String?
  // Optional photo — leaders use this to visually verify the person at the
  // door. Stored as a Cloudinary `authenticated` asset (signed on read);
  // `photoUrl` is the legacy/public fallback.
  photoUrl     String?
  photoPublicId String?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
}

// Safeguarding concern log. Highly sensitive — only the Designated
// Safeguarding Lead(s) and SUPER_ADMIN may read / manage these. Any
// CHILDREN_LEADER (or SUPER_ADMIN) may RAISE one.
//
// A concern may optionally be linked to a registered child; `childName`
// snapshots the name at the time it was raised so the record reads
// correctly even if the child is later deleted, and supports standalone
// concerns (about a visiting adult, a leader, or a general observation)
// where no `childId` is set.
model SafeguardingConcern {
  id           String          @id @default(cuid())
  childId      String?
  childName    String?
  concernType  ConcernType
  // What was witnessed / disclosed.
  description  String          @db.Text
  // What the person raising it did at the time.
  actionTaken  String?         @db.Text
  // Free text: who was informed (DSL, parents, etc.).
  whoNotified  String?         @db.Text
  // Whether this has been referred to the local authority (Devon MASH) /
  // social care.
  referredToMash Boolean       @default(false)
  occurredAt   DateTime
  status       ConcernStatus   @default(OPEN)

  raisedById   String
  raisedBy     User            @relation("ConcernRaisedBy", fields: [raisedById], references: [id], onDelete: Restrict)

  // DSL resolution fields, set when the concern is closed.
  resolution   String?         @db.Text
  closedById   String?
  closedBy     User?           @relation("ConcernClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  closedAt     DateTime?

  child        Child?          @relation(fields: [childId], references: [id], onDelete: SetNull)

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
  @@index([childId])
  @@index([occurredAt])
  @@index([referredToMash])
}

enum ConcernType {
  DISCLOSURE
  PHYSICAL
  EMOTIONAL
  SEXUAL
  NEGLECT
  BEHAVIOURAL
  ONLINE
  ALLEGATION_AGAINST_ADULT
  OTHER
}

enum ConcernStatus {
  OPEN
  MONITORING
  CLOSED
}

// One row per drop-off / pick-up cycle. `signedOutAt` and `signedOutById`
// are null while the child is still in the children's-ministry care.
//
// `performance` captures the teacher's free-text note on how the child did
// that session. It may be set at check-out time or filled in later (which
// is why `performanceUpdatedAt` is tracked separately from the row's
// natural update timestamp).
//
// `pickupCode` is a short numeric code generated at check-in and emailed
// to the primary guardian. The guardian must present this code at pickup
// before the Children Leader can close the check-in. The code lives only
// for the duration of the open check-in (no separate expiry / hashing —
// see CHILDREN_LEADER_CUTOVER.md for the rationale).
model ChildCheckIn {
  id                    String    @id @default(cuid())
  childId               String
  signedInAt            DateTime  @default(now())
  signedInById          String
  signedOutAt           DateTime?
  signedOutById         String?
  performance           String?   @db.Text
  performanceUpdatedAt  DateTime?
  pickupCode            String?

  // Who collected the child (snapshot at pickup time so the audit trail
  // survives if the AuthorisedCollector record is later edited / removed).
  // `collectedFromList=true` means the collector was a named entry on the
  // child's AuthorisedCollector list (or the primary guardian);
  // `collectedFromList=false` is an off-list override, in which case
  // `collectionNotes` should explain why.
  collectedByName       String?
  collectedByRelationship String?
  collectedFromList     Boolean   @default(false)
  collectionNotes       String?   @db.Text

  child       Child @relation(fields: [childId], references: [id], onDelete: Cascade)
  signedInBy  User  @relation("CheckInSignedInBy", fields: [signedInById], references: [id], onDelete: Restrict)
  signedOutBy User? @relation("CheckInSignedOutBy", fields: [signedOutById], references: [id], onDelete: Restrict)

  @@index([childId])
  @@index([signedInAt])
  @@index([signedOutAt])
  @@index([signedInById])
  @@index([collectedFromList])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model TwoFactorCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String // CREATE, UPDATE, DELETE
  entityType String // Book, Event, Group, etc.
  entityId   String
  changes    Json? // Store before/after values
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// Books Management
model Book {
  id            String   @id @default(cuid())
  title         String
  author        String
  category      String
  description   String   @db.Text
  coverImage    String // URL to image
  purchaseUrl   String?
  published     Boolean  @default(false)
  // Book-of-the-Month: when `featured` is true, the book appears in the
  // homepage BooksSection. `featuredOrder` controls position
  // (1 = big featured slot, 2-3 = small secondary slots).
  featured      Boolean  @default(false)
  featuredOrder Int      @default(0)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([published])
  @@index([category])
  @@index([featured])
  @@index([featuredOrder])
}

// Events Management
model Event {
  id               String   @id @default(cuid())
  title            String
  description      String   @db.Text
  date             DateTime
  time             String?
  location         String?
  imageSrc         String?
  imageAlt         String?
  registrationHref String?
  published        Boolean  @default(false)
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  notifications EventNotification[]

  @@index([published])
  @@index([date])
}

// Event-notification subscriptions (visitors who clicked "Get Notified")
model EventNotification {
  id         String    @id @default(cuid())
  eventId    String
  name       String
  email      String
  // Set when the reminder email was successfully sent.
  // Null means "not yet notified".
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@index([eventId])
  @@index([notifiedAt])
}

// Groups Management — represents a ministry/unit/department with full
// "departmental board" content (scripture banner, head responsibilities,
// programmes & sub-units, optional special-role callout, three vision-pillar
// statements). Every group follows the same template; each fills its own data.
model Group {
  id                 String   @id @default(cuid())
  // URL-safe slug used by the public detail page at /groups/[slug].
  slug               String   @unique
  title              String
  // Short tag/category shown on the homepage MinistriesSection card
  // (e.g. "KING'S CLUB", "HOUSE FELLOWSHIPS"). Falls back to uppercased title.
  tag                String?
  // Short blurb shown on the listing card.
  description        String   @db.Text
  imageSrc           String
  imageAlt           String
  ctaLabel           String?
  ctaHref            String?
  order              Int      @default(0)
  published          Boolean  @default(false)

  // Departmental-board fields (all optional — the detail page conditionally
  // renders sections that are filled in).
  scripture          String?  @db.Text
  headTitle          String?
  // string[] — numbered responsibilities of the Head.
  responsibilities   Json?
  // { title: string, schedule?: string }[] — programmes & sub-units.
  programmes         Json?
  // { title: string, body: string } | null — single highlighted callout.
  specialRole        Json?
  furnishStatement   String?  @db.Text
  transformStatement String?  @db.Text
  influenceStatement String?  @db.Text

  members     GroupMember[]

  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([order])
}

// Testimonials — short member quotes shown on the homepage TestimonialsSection.
model Testimonial {
  id          String   @id @default(cuid())
  quote       String   @db.Text
  name        String
  memberSince Int
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([order])
}

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  SINGLE
  ENGAGED
  MARRIED
  SEPARATED
  DIVORCED
  WIDOWED
}

// New-member submissions from the public "Get Involved" form on
// /groups/[slug]. Captured here so the admin team can review and follow up.
model GroupMember {
  id                  String        @id @default(cuid())
  groupId             String
  firstName           String
  lastName            String
  email               String
  phoneNumber         String
  birthDay            Int           // 1-31
  birthMonth          Int           // 1-12
  gender              Gender
  maritalStatus       MaritalStatus
  address             String        @db.Text
  filledWithHolyGhost Boolean
  createdAt           DateTime      @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([createdAt])
  @@index([email])
}

model MembershipApplication {
  id              String        @id @default(cuid())
  membershipClass String
  firstName       String
  lastName        String
  email           String        @unique
  phoneNumber     String
  gender          Gender
  maritalStatus   MaritalStatus
  streetAddress   String
  city            String
  stateProvince   String
  country         String
  rccgMember      Boolean
  saved           Boolean
  expectations    String?       @db.Text
  createdAt       DateTime      @default(now())

  @@index([createdAt])
  @@index([membershipClass])
}

model VolunteerInterest {
  id                    String   @id @default(cuid())
  name                  String
  email                 String
  phoneNumber           String
  gender                Gender?  // nullable in DB so existing rows survive the migration without a backfill; Zod requires it on every new submission
  address               String   @db.Text
  areaStrengths         Json
  pastExperience        String   @db.Text
  contributionStatement String   @db.Text
  bornAgain             Boolean
  filledWithHolyGhost   Boolean
  createdAt             DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// Program Interest — general "stay in the loop" signups captured by the
// "Get Notified" modal on the homepage live-stream section. Distinct from
// EventNotification (which is tied to a specific event for cron reminders).
// Admins use this list to send broadcast emails about upcoming programmes.
model ProgramInterest {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Adult Attendance — public walk-up form at /attendance, used to track
// who's at each service. The `service` field is a free-text string but is
// validated against a fixed list (see lib/types/attendance.ts) so reports
// can compare like-for-like.
model AdultAttendance {
  id         String   @id @default(cuid())
  name       String
  email      String
  service    String
  attendedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([service])
  @@index([attendedAt])
}

// Sermons Management
model Sermon {
  id          String   @id @default(cuid())
  title       String
  series      String?
  speaker     String
  date        DateTime
  duration    String
  description String   @db.Text
  thumbnail   String
  videoUrl    String
  published   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([series])
  @@index([date])
}

// Youth Ministry — check-in / check-out (mirrors Children Ministry)
model YouthCheckIn {
  id            String    @id @default(cuid())
  userId        String
  signedInAt    DateTime  @default(now())
  signedOutAt   DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([signedInAt])
  @@index([signedOutAt])
}

// Daily Scripture — posted by admins, visible to youth members
model DailyScripture {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  reference   String   // e.g. "John 3:16"
  text        String   @db.Text
  videoUrl    String?  // YouTube URL (optional)
  published   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([published])
}

model Media {
  id         String   @id @default(cuid())
  filename   String
  url        String
  publicId   String // Cloudinary public ID
  format     String // jpg, png, pdf, etc.
  size       Int // bytes
  width      Int?
  height     Int?
  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([uploadedBy])
  @@index([createdAt])
}

// Hero Carousel Media
model HeroCarouselImage {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  imageAlt  String
  publicId  String?
  filename  String?
  format    String?
  size      Int?
  width     Int?
  height    Int?
  order     Int      @default(0)
  published Boolean  @default(false)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@index([order])
  @@index([createdAt])
}

// Tracts Management
model Tract {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String   @db.Text
  coverImage  String // Cloudinary URL
  documentUrl String // Cloudinary URL for PDF
  published   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([category])
}

// Image Gallery Management
model Gallery {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  imageUrl    String // Cloudinary URL
  imageAlt    String
  dateTaken   DateTime
  published   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([dateTaken])
}

// Information Hub
// Publicly submitted immigration notes, job posts, and other practical
// community information. Visitor submissions stay unpublished until an admin
// accepts them in the dashboard.
model InformationItem {
  id             String   @id @default(cuid())
  title          String
  description    String   @db.Text
  linkUrl        String
  category       String
  submittedBy    String?
  submitterEmail String?
  published      Boolean  @default(false)
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published])
  @@index([category])
  @@index([createdAt])
}
